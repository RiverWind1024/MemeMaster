<?xml version="1.0" encoding="utf-8"?>
<!--
    定义 Android 自动备份的范围。
    Android 12+ 使用 dataExtractionRules，旧版本使用 backupAgent / fullBackupContent。
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- 数据库 -->
        <include domain="database" path="meme_helper.db" />
        <include domain="database" path="meme_helper.db-wal" />
        <include domain="database" path="meme_helper.db-shm" />
        <!-- SharedPreferences -->
        <include domain="sharedpref" path="." />
        <!-- 图片文件 -->
        <include domain="file" path="app_flutter/memes/" />
        <include domain="file" path="logs/" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="meme_helper.db" />
        <include domain="database" path="meme_helper.db-wal" />
        <include domain="database" path="meme_helper.db-shm" />
        <include domain="sharedpref" path="." />
        <include domain="file" path="app_flutter/memes/" />
        <include domain="file" path="logs/" />
    </device-transfer>
</data-extraction-rules>
